# AI provider: groq (default), gemini, or claude
AI_PROVIDER=groq

# Groq (used when AI_PROVIDER=groq) — generous free tier, recommended for testing
GROQ_API_KEY=your_groq_key_here
# Cost-effective options: llama-3.1-8b-instant (cheapest) | llama-3.3-70b-versatile (best quality)
GROQ_MODEL=llama-3.3-70b-versatile

# Gemini (used when AI_PROVIDER=gemini)
GEMINI_API_KEY=your_gemini_key_here
GEMINI_MODEL=gemini-2.0-flash-lite
GEMINI_STEP_DELAY=8
GEMINI_MAX_RETRIES=3
GEMINI_MAX_RETRY_DELAY=30

# Claude (used when AI_PROVIDER=claude)
ANTHROPIC_API_KEY=your_claude_key_here
CLAUDE_MODEL=claude-sonnet-4-6
